var vmDisk = vmInfo.getAttributeWithKey("vmDisk").value;

vmNbOfCpus = vmCPU;
vmDiskSize = vmDisk;
System.log(vmNbOfCpus);
System.log(vmMemorySize);
System.log(vmDiskSize);
System.log(vmName);
</script>
        <in-binding>
