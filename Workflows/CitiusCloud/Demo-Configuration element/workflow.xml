        <display-name>Scriptable task</display-name>
        <script encoded="false">System.log("Resource Name: " + home.name);

var mimeAttachment = home.getContentAsMimeAttachment();

var content = mimeAttachment.content;

System.log("File Content:");
System.log(content);</script>
        <in-binding>
